DATABASE_URL=xxxxxxx
JWT_SECRET=your-secret-key-change-this
# Admins are read directly from env — no DB seeding.
# Generate a bcrypt hash for any plaintext password with:
#   cd server && node -e "console.log(require('bcrypt').hashSync(process.argv[1], 10))" 'yourPlainPassword'
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
# Optional extra admins. Slots _3 and _4 also supported.
ADMIN_USERNAME_2=
ADMIN_PASSWORD_2_HASH=
FRONTEND_URL=someurl

# --- Meta (Facebook) Conversions API ----------------------------------------
# Pixel ID is the same one wired in src/index.html (currently 780880514467909).
META_PIXEL_ID=780880514467909
# Generate at: Events Manager → your Pixel → Settings → Conversions API → Generate access token
META_CAPI_ACCESS_TOKEN=replace-with-long-lived-capi-token
# OPTIONAL: while testing, paste the Test Event Code from
#   Events Manager → Test Events tab.
# Leave empty in production so events count toward real attribution.
META_CAPI_TEST_EVENT_CODE=

# --- Resend (booking emails) ------------------------------------------------
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Sender MUST be on a domain verified in Resend. The shared test sender
# onboarding@resend.dev only delivers to your own Resend account email — it is
# NOT usable in production. Once endurobrothersbulgaria.com is verified, use:
BOOKING_FROM_EMAIL=Enduro Brothers <bookings@endurobrothersbulgaria.com>
# Where the internal "new booking" notification is sent (replies go to the customer).
# The /api/contact endpoint (contact form + floating-help bubble) also sends its
# staff notification here, so one inbox covers both bookings and contact messages.
BOOKING_NOTIFY_EMAIL=you@example.com
